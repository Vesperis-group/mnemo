{
  "git": {
    "commitMessage": "chore: release v${version} [skip ci]",
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}",
    "requireBranch": "main",
    "requireCleanWorkingDir": true,
    "requireUpstream": false,
    "addUntrackedFiles": false,
    "commit": true,
    "tag": true,
    "push": true
  },
  "github": {
    "release": true,
    "releaseName": "mnemo v${version}",
    "autoGenerate": false,
    "assets": [
      "mnemo-v*-linux-*.tar.gz",
      "mnemo-v*-linux-*.tar.gz.sha256",
      "mnemo-v*-sbom.cdx.json",
      "mnemo-v*-sbom.cdx.json.sha256",
      "mnemo-v*-checksums.txt",
      "mnemo-v*.sigstore.json"
    ]
  },
  "npm": {
    "publish": false,
    "ignoreVersion": true
  },
  "hooks": {
    "after:bump": [
      "cargo build --release",
      "MNEMO_VERSION=${version} MNEMO_TARGET_LABEL=x86_64-unknown-linux-gnu-glibc2.35 MNEMO_BINARY_PATH=target/release/mnemo bash scripts/package-release.sh",
      "cargo build --release --target x86_64-unknown-linux-musl",
      "MNEMO_VERSION=${version} MNEMO_TARGET_LABEL=x86_64-unknown-linux-musl MNEMO_BINARY_PATH=target/x86_64-unknown-linux-musl/release/mnemo bash scripts/package-release.sh",
      "MNEMO_VERSION=${version} bash scripts/generate-sbom.sh",
      "MNEMO_VERSION=${version} bash scripts/checksums-release.sh",
      "MNEMO_VERSION=${version} bash scripts/sign-release.sh"
    ]
  },
  "plugins": {
    "@release-it/bumper": {
      "in": {
        "file": "Cargo.toml",
        "path": "package.version"
      },
      "out": {
        "file": "Cargo.toml",
        "path": "package.version"
      }
    },
    "@release-it/conventional-changelog": {
      "infile": "CHANGELOG.md",
      "header": "# Changelog\n",
      "preset": {
        "name": "conventionalcommits"
      }
    }
  }
}
